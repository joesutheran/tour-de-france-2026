# Copy to tools/.webhook.env (gitignored) and fill in. Sourced by run_listener.sh.
# Generate a secret with:  openssl rand -hex 24
TDF_WEBHOOK_SECRET=replace-with-a-long-random-string

# Optional overrides (defaults shown):
# TDF_WEBHOOK_HOST=127.0.0.1
# TDF_WEBHOOK_PORT=8787
# TDF_WEBHOOK_TYPES=tdf_daily
